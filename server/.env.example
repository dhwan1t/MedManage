# ═══════════════════════════════════════════════════════════════
# MedManage Server — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values before starting.
#
#   cp .env.example .env
#
# REQUIRED variables will cause the server to exit if missing.
# OPTIONAL variables have sensible defaults.
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────

# JWT secret used to sign and verify authentication tokens.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# MongoDB connection URI.
# For local development: mongodb://localhost:27017/mediroute
# For Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mediroute
MONGO_URI=

# ── OPTIONAL ──────────────────────────────────────────────────

# Port the Express server listens on (default: 5001)
PORT=5001

# Comma-separated list of allowed CORS origins.
# In development the Vite dev server runs on localhost:5173.
# In production set this to your real frontend domain(s).
# Default (if unset): http://localhost:5173,http://localhost:4173,http://localhost:3000
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ── SEED SCRIPT ───────────────────────────────────────────────

# Password used for all demo/seed users created by `npm run seed`.
# If not set, a random password is generated and printed to the console.
# NEVER use a weak password like "pass123" in any environment.
SEED_PASSWORD=
